# Super Coder — Unified LLM Proxy Config
# Copy this file to config.yaml and edit as needed.
#
# QUICK SETUP CHECKLIST
#   [ ] Ollama installed & running     →  https://ollama.com  then: ollama serve
#       Pull models:  ollama pull qwen3-coder   (30B, best quality)
#                     ollama pull qwen2.5-coder  (7B, fast)
#                     ollama pull codellama:7b   (7B, lightweight)
#   [ ] Copilot CLI authenticated      →  copilot auth login
#   [ ] Claude CLI authenticated       →  claude auth login
#   [ ] Gemini Web (optional)          →  sign into gemini.google.com in Chrome
#   [ ] Gemini API (optional, free)    →  export GOOGLE_API_KEY="AIza..."
#                                         get key: https://aistudio.google.com/app/apikey
#
# HOW TO ADD A MODEL
#   Option A — New Ollama model (no backend needed):
#     aliases:
#       my-model:
#         backend: ollama
#         model: <ollama-model-name>   # e.g. llama3.2, mistral, deepseek-coder
#
#   Option B — New Copilot model:
#     backends:
#       copilot_newmodel:
#         type: cli
#         cli_binary: copilot
#         cli_args: ["--model", "<copilot-model-id>", "-s", "--allow-all"]
#     aliases:
#       my-copilot-model:
#         backend: copilot_newmodel
#         model: my-copilot-model
#
#   Option C — Any OpenAI-compatible API (Groq, Together, OpenRouter, etc.):
#     backends:
#       groq:
#         type: openai_compatible
#         base_url: https://api.groq.com/openai/v1
#         api_key_env: GROQ_API_KEY    # or: api_key: <your-key>
#     aliases:
#       llama-groq:
#         backend: groq
#         model: llama-3.3-70b-versatile

aliases:
  # ── 1. GitHub Copilot (requires: copilot auth login) ──────────────────────
  copilot-opus:
    backend: copilot_opus
    model: copilot-opus          # claude-opus-4.6 via Copilot

  copilot-gpt:
    backend: copilot_gpt
    model: copilot-gpt           # GPT-5.3 Codex — current flagship

  copilot-gpt-mini:
    backend: copilot_gpt_mini
    model: copilot-gpt-mini      # GPT-5 Mini — fastest

  copilot-raptor-mini:
    backend: copilot_raptor_mini
    model: copilot-raptor-mini   # gpt-5.1-codex-mini

  # ── 2. Claude Pro (requires: claude auth login) ───────────────────────────
  claude-smart:
    backend: claude_smart
    model: claude-smart          # auto-selects best Claude model

  # ── 3. Local Ollama (requires: ollama serve + ollama pull <model>) ─────────
  super-coder:
    backend: ollama
    model: qwen3-coder           # ollama pull qwen3-coder

  super-coder-fast:
    backend: ollama
    model: qwen2.5-coder         # ollama pull qwen2.5-coder

  super-coder-lite:
    backend: ollama
    model: codellama:7b          # ollama pull codellama:7b

  # ── 4. Gemini Web (requires: Chrome signed into gemini.google.com) ─────────
  gemini-flash-web:
    backend: gemini_web
    model: gemini-3.0-flash      # fast, generous quota

  gemini-pro-web:
    backend: gemini_web
    model: gemini-3.1-pro        # most capable Gemini

  gemini-thinking-web:
    backend: gemini_web
    model: gemini-3.0-flash-thinking  # extended thinking mode

  # ── 5. Gemini API (requires: export GOOGLE_API_KEY="AIza...") ─────────────
  gemini-flash-api:
    backend: gemini_api
    model: gemini-2.0-flash      # 15 RPM free tier

  gemini-pro-api:
    backend: gemini_api
    model: gemini-2.5-pro-preview-05-06  # 2 RPM free tier

backends:
  # ── Local Ollama ───────────────────────────────────────────────────────────
  ollama:
    type: openai_compatible
    base_url: http://localhost:11434/v1
    api_key: ollama              # any non-empty string works

  # ── Claude Code CLI ───────────────────────────────────────────────────────
  # No --model flag = auto-selects best available (Opus → Sonnet → Haiku)
  # Auth: claude auth login
  claude_smart:
    type: cli
    cli_binary: claude

  # ── GitHub Copilot CLI ────────────────────────────────────────────────────
  # --allow-all is required for non-interactive (-p) mode
  # Auth: copilot auth login
  copilot_opus:
    type: cli
    cli_binary: copilot
    cli_args: ["--model", "claude-opus-4.6", "-s", "--allow-all"]

  copilot_gpt:
    type: cli
    cli_binary: copilot
    cli_args: ["--model", "gpt-5.3-codex", "-s", "--allow-all"]

  copilot_gpt_mini:
    type: cli
    cli_binary: copilot
    cli_args: ["--model", "gpt-5-mini", "-s", "--allow-all"]

  copilot_raptor_mini:
    type: cli
    cli_binary: copilot
    cli_args: ["--model", "gpt-5.1-codex-mini", "-s", "--allow-all"]

  # ── Gemini Web ─────────────────────────────────────────────────────────────
  # Cookies are auto-extracted from Chrome by default.
  # For reliability (avoids macOS Keychain prompts), paste them explicitly:
  #   1. Open Chrome → gemini.google.com → sign in
  #   2. F12 → Application → Cookies → https://gemini.google.com
  #   3. Copy __Secure-1PSID and __Secure-1PSIDTS values below
  gemini_web:
    type: gemini_web
    cookies:
      __Secure-1PSID: ""        # leave empty for auto-extract, or paste value
      __Secure-1PSIDTS: ""      # leave empty for auto-extract, or paste value

  # ── Gemini API ─────────────────────────────────────────────────────────────
  # Set env var before starting the proxy:
  #   export GOOGLE_API_KEY="AIza..."
  # Get a free key: https://aistudio.google.com/app/apikey
  gemini_api:
    type: gemini
    api_key_env: GOOGLE_API_KEY

server:
  host: 127.0.0.1
  port: 8000
  log_level: info               # options: debug, info, warning, error
